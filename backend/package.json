{
  "name": "etaxes-plus",
  "version": "1.0.0",
  "description": "Backend para ETaxes+",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:watch": "node --watch server.js",
    "setup-db": "mysql -u root -p'Error404.' -P 3307 < setup.sql",
    "migrate": "node scripts/migrate.js",
    "audit": "node scripts/agent.js --audit",
    "agent": "node scripts/agent.js",
    "test:endpoints": "node scripts/agent.js --test"
  },
  "dependencies": {
    "@nodecfdi/cfdi-core": "^1.0.1",
    "@nodecfdi/credentials": "^3.2.0",
    "@nodecfdi/sat-ws-descarga-masiva": "^2.0.0",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.4.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.1",
    "python-shell": "^5.0.0",
    "xml2js": "^0.6.2"
  }
}
