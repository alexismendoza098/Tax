# ─────────────────────────────────────────────────────────────────────────────
# ETX Tax Recovery — Plantilla de variables de entorno
#
# 1. Copia este archivo como .env en el servidor
# 2. Rellena TODOS los valores (no dejes los de ejemplo)
# 3. NUNCA subas .env al repositorio Git
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos MySQL ───────────────────────────────────────────────────────
# En local XAMPP: localhost, puerto 3307
# En Railway/PlanetScale/AWS RDS: usa el host que te dan en el panel
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CAMBIA_ESTO_POR_TU_PASSWORD
DB_NAME=IVATAXRECOVERY

# ── Seguridad ────────────────────────────────────────────────────────────────
# Genera un secreto aleatorio fuerte (min. 32 chars):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_ALEATORIO_MUY_LARGO

# ── Servidor ─────────────────────────────────────────────────────────────────
# Railway/Render/Heroku asignan PORT automáticamente — no lo cambies en prod
PORT=3000
NODE_ENV=production

# ── CORS — URL de tu frontend en la nube ─────────────────────────────────────
# Puede ser múltiple separado por comas:
#   FRONTEND_URL=https://mi-app.up.railway.app,https://www.midominio.com
# Si frontend y backend están en la misma URL, usa esa URL sola.
FRONTEND_URL=https://TU-DOMINIO.com
