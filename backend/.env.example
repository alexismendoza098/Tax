# ─────────────────────────────────────────────────────────────────────────────
# ETaxes+ — Plantilla de variables de entorno
#
# Instrucciones:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena TODOS los valores con tus datos reales
#   3. NUNCA subas .env al repositorio Git (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos MySQL ───────────────────────────────────────────────────────
# XAMPP local: host=localhost, puerto=3307
# XAMPP a veces usa 3306 — revisa en phpMyAdmin → Servidor → Puerto
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=CAMBIA_ESTO_POR_TU_PASSWORD
DB_NAME=ETaxes2_0

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Genera un secreto aleatorio fuerte (mínimo 32 caracteres):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_ALEATORIO_MUY_LARGO

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS — URLs permitidas del frontend ──────────────────────────────────────
# Para desarrollo local: deja vacío o pon http://localhost
# Para producción: pon tu dominio real (puede ser múltiple separado por comas)
#   FRONTEND_URL=https://mi-app.com,https://www.mi-app.com
FRONTEND_URL=
